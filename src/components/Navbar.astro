---
import { Icon } from "astro-icon/components";

const pathname = Astro.url.pathname;

function isActive(href: string) {
    if (href === "/") return pathname === "/";
    return pathname.startsWith(href);
}

const navLinks = [
    { href: "https://portal.kemenagkotaprobolinggo.id", label: "Portal" },
    { href: "/", label: "Layanan" },
    { href: "/check-progress", label: "Cek Progress" },
    { href: "/pengaduan", label: "Pengaduan" },
    { href: "/information", label: "Informasi" },
];

const navButtons = [
    // {
    //     href: "/admin",
    //     label: "Masuk",
    //     bg: "bg-green",
    //     icon: "mdi:account",
    // },
    {
        href: "/internal",
        label: "ASN",
        bg: "bg-yellow",
        icon: "mdi:accounts",
    },
];
---

<!-- ── Desktop & mobile wrapper ──────────────────────────────── -->
<header class="relative">
    <nav class="flex justify-between items-center py-4 lg:py-5">
        <!-- Logo -->
        <div class="flex gap-3 items-center">
            <img src="/logo.png" class="w-10 lg:w-13" alt="Logo" />
            <div
                class="font-semibold -space-y-1 lg:-space-y-2 uppercase leading-tight"
            >
                <h3 class="text-[11px] lg:text-sm">Kantor Kementerian Agama</h3>
                <h3 class="text-[11px] lg:text-sm">Kota Probolinggo</h3>
            </div>
        </div>

        <!-- Desktop nav links (lg+) -->
        <ul class="hidden lg:flex gap-5 uppercase font-semibold text-sm">
            {
                navLinks.map((l) => (
                    <li>
                        <a
                            href={l.href}
                            class={`nav-link ${isActive(l.href) ? "active" : ""}`}
                        >
                            {l.label}
                        </a>
                    </li>
                ))
            }
        </ul>

        <!-- Desktop login buttons (lg+) -->
        <ul class="hidden lg:flex items-center font-semibold text-sm">
            {
                navButtons.map((b) => (
                    <li>
                        <a
                            href={b.href}
                            class={`btn-asn py-3 uppercase ${b.label == "Masuk" ? "text-white" : ""} ${b.label == "Masuk" ? "px-7" : "px-10"} flex items-center gap-2 cursor-pointer ${b.bg}`}
                        >
                            <Icon name={b.icon} />
                            {b.label}
                        </a>
                    </li>
                ))
            }
        </ul>

        <!-- Mobile & tablet: hamburger (< lg) -->
        <button
            id="mobile-menu-btn"
            class="lg:hidden flex flex-col justify-center items-center w-9 h-9 gap-1.5 cursor-pointer"
            aria-label="Buka menu"
            aria-expanded="false"
        >
            <span
                class="ham-line block w-6 h-0.5 bg-ink rounded transition-all duration-300 origin-center"
            ></span>
            <span
                class="ham-line block w-6 h-0.5 bg-ink rounded transition-all duration-300"
            ></span>
            <span
                class="ham-line block w-6 h-0.5 bg-ink rounded transition-all duration-300 origin-center"
            ></span>
        </button>
    </nav>

    <!-- Mobile & tablet drawer (< lg) -->
    <div
        id="mobile-menu"
        class="mobile-drawer lg:hidden overflow-hidden"
        style="max-height: 0; transition: max-height 0.35s cubic-bezier(0.4,0,0.2,1);"
    >
        <div class="border-t border-ink/8 pt-3 pb-5">
            <!-- Nav links: 1-col on mobile, 2-col grid on tablet -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-0.5">
                {
                    navLinks.map((l) => (
                        <a
                            href={l.href}
                            class={`flex items-center gap-3 px-3 py-2.5 text-sm font-semibold uppercase rounded-lg transition-colors
                ${isActive(l.href) ? "text-green bg-green/5" : "text-ink/60 hover:text-ink hover:bg-black/4"}`}
                        >
                            {l.label}
                            {isActive(l.href) && (
                                <span class="ml-auto w-1.5 h-1.5 rounded-full bg-green shrink-0" />
                            )}
                        </a>
                    ))
                }
            </div>

            <!-- Divider -->
            <div class="my-3 border-t border-ink/8"></div>

            <!-- Login buttons -->
            <div class="flex flex-col sm:flex-row gap-2">
                {
                    navButtons.map((b) => (
                        <a
                            href={b.href}
                            class={`btn-asn ${b.bg} font-bold uppercase text-sm px-5 py-3
                flex items-center justify-between sm:justify-center gap-2 cursor-pointer sm:flex-1`}
                        >
                            <Icon name={b.icon} />
                            <span>{b.label}</span>
                        </a>
                    ))
                }
            </div>
        </div>
    </div>
</header>

<style>
    .nav-link {
        position: relative;
        padding-bottom: 4px;
        color: inherit;
        transition: color 0.2s ease;
    }
    .nav-link::after {
        content: "";
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        height: 2px;
        background-color: #0f6b44;
        transform: scaleX(0);
        transform-origin: left;
        transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .nav-link.active {
        color: #0f6b44;
    }
    .nav-link.active::after {
        transform: scaleX(1);
    }

    .btn-masuk,
    .btn-asn {
        position: relative;
        overflow: hidden;
        transition:
            transform 0.2s ease,
            box-shadow 0.2s ease;
    }
    .btn-masuk::before,
    .btn-asn::before {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(
            120deg,
            transparent 30%,
            rgba(255, 255, 255, 0.18) 50%,
            transparent 70%
        );
        transform: translateX(-100%);
        transition: transform 0.45s ease;
    }
    .btn-masuk:hover::before,
    .btn-asn:hover::before {
        transform: translateX(100%);
    }
    .btn-masuk:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(15, 107, 68, 0.35);
    }
    .btn-asn:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(246, 199, 68, 0.4);
    }
    .btn-masuk:active,
    .btn-asn:active {
        transform: translateY(0) scale(0.97);
    }

    /* Hamburger → X animation */
    #mobile-menu-btn.open .ham-line:nth-child(1) {
        transform: translateY(8px) rotate(45deg);
    }
    #mobile-menu-btn.open .ham-line:nth-child(2) {
        opacity: 0;
        transform: scaleX(0);
    }
    #mobile-menu-btn.open .ham-line:nth-child(3) {
        transform: translateY(-8px) rotate(-45deg);
    }
</style>

<script>
    function initMobileMenu() {
        const btn = document.getElementById("mobile-menu-btn");
        const drawer = document.getElementById("mobile-menu");
        if (!btn || !drawer) return;

        const button = btn as HTMLElement;
        const drawerEl = drawer as HTMLElement;

        button.addEventListener("click", () => {
            if (button.classList.contains("open")) {
                drawerEl.style.maxHeight = "0";
                button.classList.remove("open");
                button.setAttribute("aria-expanded", "false");
            } else {
                drawerEl.style.maxHeight = drawerEl.scrollHeight + "px";
                button.classList.add("open");
                button.setAttribute("aria-expanded", "true");
            }
        });

        // Close on outside click
        document.addEventListener("click", (e) => {
            if (
                !button.contains(e.target as Node) &&
                !drawerEl.contains(e.target as Node)
            ) {
                drawerEl.style.maxHeight = "0";
                button.classList.remove("open");
                button.setAttribute("aria-expanded", "false");
            }
        });
    }

    initMobileMenu();
    document.addEventListener("astro:page-load", initMobileMenu);
</script>
