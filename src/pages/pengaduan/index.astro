---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FormPengaduan from '../../components/Svelte/FormPengaduan.svelte';
---

<style>
  [data-anim="badge"] {
    animation: slideDown 0.5s cubic-bezier(0.16, 1, 0.3, 1) 0.05s both;
  }
  [data-anim="heading"] {
    animation: slideUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.15s both;
  }
  [data-anim="desc"] {
    animation: slideUp 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.3s both;
  }
  [data-anim="form"] {
    animation: slideUp 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.45s both;
  }

  @keyframes slideDown {
    from { opacity: 0; transform: translateY(-14px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes slideUp {
    from { opacity: 0; transform: translateY(28px); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>

<BaseLayout title="Pengaduan - Kemenag Kota Probolinggo">
  <section class="py-8 md:py-16 flex flex-col gap-5 md:gap-8">
    <div>
      <div data-anim="badge" class="font-semibold mb-2 bg-yellow w-fit px-3 md:px-4 py-1.5 md:py-2 uppercase text-xs md:text-sm tracking-wide">
        Pengaduan Masyarakat
      </div>
      <h1 data-anim="heading" class="text-3xl sm:text-4xl md:text-5xl font-bold mb-2 md:mb-3 uppercase">Sampaikan Pengaduan Anda</h1>
      <p data-anim="desc" class="text-sm md:text-base opacity-70 max-w-xl">
        Pengaduan bersifat anonim. Setelah mengirim, Anda akan mendapatkan kode unik untuk memantau status pengaduan.
      </p>
    </div>

    <div data-anim="form">
      <FormPengaduan client:load />
    </div>
  </section>
</BaseLayout>
