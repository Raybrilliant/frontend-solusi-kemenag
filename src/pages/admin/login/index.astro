---
import "../../../styles/global.css";
import AdminLoginForm from "../../../components/Svelte/AdminLoginForm.svelte";
import { Icon } from "astro-icon/components";

const features = [
    {
        icon: "mdi:account-cog",
        label: "Kelola permohonan layanan & pantau status real-time",
    },
    {
        icon: "mdi:account-multiple",
        label: "Manajemen pengguna, kategori, dan data layanan",
    },
    {
        icon: "mdi:chart-bar",
        label: "Laporan & analitik kinerja layanan publik",
    },
    {
        icon: "mdi:cog-outline",
        label: "Pengaturan sistem, dokumen, dan survey kepuasan",
    },
];
---

<html lang="id">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="viewport" content="width=device-width" />
        <title>Login Admin — Kemenag Kota Probolinggo</title>
    </head>

    <body class="h-screen grid grid-cols-2 overflow-hidden bg-cream">
        <!-- ══════════════════════════════════════════════════════════
         LEFT PANEL — brand & feature info (static)
    ══════════════════════════════════════════════════════════════ -->
        <div class="flex flex-col relative overflow-hidden h-full">
            <!-- Backgrounds -->
            <div
                class="absolute inset-0 bg-linear-to-br from-[#0a1a0c] via-[#0f2212] to-[#071510]"
            >
            </div>
            <div class="absolute inset-0 dot-grid opacity-[0.07]"></div>
            <div
                class="absolute -bottom-24 -left-24 w-96 h-96 bg-green/20 rounded-full blur-3xl pointer-events-none"
            >
            </div>
            <div
                class="absolute top-1/3 right-0 w-64 h-64 bg-green/10 rounded-full blur-3xl pointer-events-none"
            >
            </div>

            <!-- Content -->
            <div class="relative z-10 flex flex-col h-full px-12 py-10">
                <!-- Logo -->
                <div data-anim="logo" class="flex items-center gap-3">
                    <div
                        class="w-10 h-10 rounded-xl bg-white/10 border border-white/20 flex items-center justify-center shrink-0"
                    >
                        <img
                            src="/logo.png"
                            class="w-6 h-6 object-contain"
                            alt="Logo"
                        />
                    </div>
                    <div>
                        <p
                            class="text-[9px] font-extrabold uppercase tracking-[0.15em] text-white/35 leading-none"
                        >
                            Kementerian Agama
                        </p>
                        <p
                            class="text-[13px] font-bold text-white leading-tight"
                        >
                            Kota Probolinggo
                        </p>
                    </div>
                </div>

                <!-- Hero text -->
                <div class="flex-1 flex flex-col justify-center max-w-md">
                    <div
                        data-anim="badge"
                        class="inline-flex items-center gap-2 bg-green/20 border border-green/30 rounded-full px-3 py-1 mb-6 w-fit"
                    >
                        <span
                            class="w-1.5 h-1.5 rounded-full bg-green animate-pulse"
                        ></span>
                        <span
                            class="text-[11px] font-bold text-green/90 uppercase tracking-widest"
                            >Panel Admin</span
                        >
                    </div>

                    <h1
                        data-anim="heading"
                        class="text-3xl xl:text-4xl font-extrabold text-white uppercase leading-tight mb-4"
                    >
                        Kelola layanan<br />
                        <span class="text-green">publik</span> dengan mudah
                    </h1>

                    <p
                        data-anim="desc"
                        class="text-sm text-white/45 leading-relaxed mb-10"
                    >
                        Sistem manajemen layanan Kementerian Agama Kota
                        Probolinggo. Akses khusus untuk pegawai yang berwenang.
                    </p>

                    <!-- Feature list -->
                    <div data-anim="features" class="space-y-4">
                        {
                            features.map((f, i) => (
                                <div
                                    class="flex items-start gap-3"
                                    style={`animation-delay:${0.3 + i * 0.1}s`}
                                >
                                    <div class="w-8 h-8 rounded-lg bg-green/15 border border-green/20 flex items-center justify-center shrink-0 mt-0.5">
                                        <Icon
                                            name={f.icon}
                                            width="16"
                                            height="16"
                                            class="text-green"
                                        />
                                    </div>
                                    <p class="text-[13px] text-white/55 leading-snug pt-1.5">
                                        {f.label}
                                    </p>
                                </div>
                            ))
                        }
                    </div>
                </div>

                <!-- Bottom note -->
                <div
                    data-anim="footer"
                    class="flex items-center gap-2 border-t border-white/8 pt-5"
                >
                    <Icon
                        name="mdi:lock"
                        width="16"
                        height="16"
                        class="text-white/25"
                    />
                    <p class="text-[11px] text-white/25">
                        Akses dibatasi. Hanya pegawai yang memiliki otorisasi
                        yang dapat masuk.
                    </p>
                </div>
            </div>
        </div>

        <!-- ══════════════════════════════════════════════════════════
         RIGHT PANEL — Svelte login form
    ══════════════════════════════════════════════════════════════ -->
        <div
            data-anim="form"
            class="flex items-center justify-center px-6 py-10 overflow-y-auto"
        >
            <div class="w-full max-w-sm">
                <!-- Mobile logo (hidden on lg+) -->
                <div class="flex items-center gap-3 mb-8 lg:hidden">
                    <div
                        class="w-9 h-9 rounded-xl bg-green flex items-center justify-center shrink-0"
                    >
                        <img
                            src="/logo.png"
                            class="w-5 h-5 object-contain"
                            alt="Logo"
                        />
                    </div>
                    <div>
                        <p
                            class="text-[9px] font-extrabold uppercase tracking-[0.15em] text-ink/35 leading-none"
                        >
                            Kementerian Agama
                        </p>
                        <p class="text-[13px] font-bold text-ink leading-tight">
                            Kota Probolinggo
                        </p>
                    </div>
                </div>

                <AdminLoginForm client:load />
            </div>
        </div>
    </body>
</html>

<style>
    .dot-grid {
        background-image: radial-gradient(circle, #fff 1px, transparent 1px);
        background-size: 28px 28px;
    }

    /* ── Entrance animations ───────────────────────────── */
    [data-anim="logo"] {
        animation: fadeDown 0.5s cubic-bezier(0.16, 1, 0.3, 1) 0.05s both;
    }
    [data-anim="badge"] {
        animation: fadeDown 0.5s cubic-bezier(0.16, 1, 0.3, 1) 0.12s both;
    }
    [data-anim="heading"] {
        animation: fadeUp 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.2s both;
    }
    [data-anim="desc"] {
        animation: fadeUp 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.28s both;
    }
    [data-anim="features"] {
        animation: fadeUp 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.36s both;
    }
    [data-anim="footer"] {
        animation: fadeUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.5s both;
    }
    [data-anim="form"] {
        animation: fadeUp 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.3s both;
    }

    @keyframes fadeDown {
        from {
            opacity: 0;
            transform: translateY(-12px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
    @keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>
