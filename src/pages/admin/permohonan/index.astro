---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import AdminPermohonanTable from "../../../components/Svelte/AdminPermohonanTable.svelte";
import AdminTambahPermohonan from "../../../components/Svelte/AdminTambahPermohonan.svelte";

const userRole = Astro.locals.user?.role ?? "";
const canAdd = userRole === "super_admin" || userRole === "admin";
---

<style>
    [data-anim="hero"] {
        animation: fadeDown 0.45s cubic-bezier(0.16, 1, 0.3, 1) 0.05s both;
    }
    [data-anim="content"] {
        animation: fadeUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.15s both;
    }

    @keyframes fadeDown {
        from {
            opacity: 0;
            transform: translateY(-12px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
    @keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<AdminLayout title="Permohonan">
    <div class="min-h-full">
        <!-- ── Hero ──────────────────────────────────── -->
        <div data-anim="hero" class="px-8 py-6 flex items-start justify-between gap-4">
            <div>
                <h1 class="text-4xl font-bold uppercase tracking-tight text-ink">
                    Permohonan
                </h1>
                <p class="text-sm text-ink/50 mt-1">
                    Kelola semua permohonan yang dikirim oleh pengguna.
                </p>
            </div>
            {canAdd && (
                <AdminTambahPermohonan client:load />
            )}
        </div>

        <!-- ── Table ──────────────────────────────────── -->
        <div data-anim="content" class="px-8 py-6">
            <AdminPermohonanTable apiUrl="/api/admin/permohonan" client:load />
        </div>
    </div>
</AdminLayout>
