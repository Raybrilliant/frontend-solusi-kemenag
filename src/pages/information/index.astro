---
import { Icon } from "astro-icon/components";
import BaseLayout from "../../layouts/BaseLayout.astro";
import RiwayatLayanan from "../../components/Svelte/RiwayatLayanan.svelte";
import TrendLayanan from "../../components/Svelte/TrendLayanan.svelte";
import KepuasanMasyarakat from "../../components/Svelte/KepuasanMasyarakat.svelte";
import KategoriPopuler from "../../components/Svelte/KategoriPopuler.svelte";
import InformationCategoryStats from "../../components/InformationCategoryStats.astro";

const BACKEND_URL = process.env.BACKEND_URL ?? "http://localhost:3000";

Astro.response.headers.set(
    "Cache-Control",
    "public, max-age=180, stale-while-revalidate=300",
);

const [
    trendRes,
    riwayatDiprosesRes,
    riwayatSelesaiRes,
    surveyRes,
    kategoriPopulerRes,
] = await Promise.allSettled([
    fetch(`${BACKEND_URL}/api/v1/dashboard/trend?period=3`),
    fetch(
        `${BACKEND_URL}/api/v1/dashboard/permohonan-terbaru?limit=5&status=Diproses`,
    ),
    fetch(
        `${BACKEND_URL}/api/v1/dashboard/permohonan-terbaru?limit=5&status=Selesai`,
    ),
    fetch(`${BACKEND_URL}/api/v1/survei/public/averages?period=12`, {
        headers: { Accept: "application/json" },
    }),
    fetch(`${BACKEND_URL}/api/v1/dashboard/kategori-populer`),
]);

function calcPct(curr: number, prev: number): number {
    if (prev === 0) return curr > 0 ? 100 : 0;
    return Math.round(((curr - prev) / prev) * 100);
}

function normalizeLabel(value: string): string {
    return value
        .toLowerCase()
        .normalize("NFD")
        .replace(/[\u0300-\u036f]/g, "")
        .replace(/[^a-z0-9]/g, "");
}

function getMonthTokens(date: Date): string[] {
    const monthIdLong = new Intl.DateTimeFormat("id-ID", {
        month: "long",
    }).format(date);
    const monthIdShort = new Intl.DateTimeFormat("id-ID", {
        month: "short",
    }).format(date);
    const monthEnLong = new Intl.DateTimeFormat("en-US", {
        month: "long",
    }).format(date);
    const monthEnShort = new Intl.DateTimeFormat("en-US", {
        month: "short",
    }).format(date);
    const year = String(date.getFullYear());
    const shortYear = year.slice(-2);

    return [
        monthIdLong,
        monthIdShort,
        monthEnLong,
        monthEnShort,
        `${monthIdLong} ${year}`,
        `${monthIdShort} ${year}`,
        `${monthEnLong} ${year}`,
        `${monthEnShort} ${year}`,
        `${monthIdLong}-${year}`,
        `${monthIdShort}-${year}`,
        `${monthEnLong}-${year}`,
        `${monthEnShort}-${year}`,
        `${monthIdLong} ${shortYear}`,
        `${monthIdShort} ${shortYear}`,
        `${monthEnLong} ${shortYear}`,
        `${monthEnShort} ${shortYear}`,
    ].map(normalizeLabel);
}

function findMonthIndex(labels: string[], date: Date): number {
    const tokens = new Set(getMonthTokens(date));
    return labels.findIndex((label) => tokens.has(normalizeLabel(label)));
}

const currentDate = new Date();
const previousDate = new Date(
    currentDate.getFullYear(),
    currentDate.getMonth() - 1,
    1,
);

let currentLabel = new Intl.DateTimeFormat("id-ID", {
    month: "long",
    year: "numeric",
}).format(currentDate);
let previousLabel = new Intl.DateTimeFormat("id-ID", {
    month: "long",
    year: "numeric",
}).format(previousDate);

let currentTotal = 0,
    currentSelesai = 0,
    currentDitolak = 0,
    currentTingkatPenyelesaian = 0;

let percentTotal = 0,
    percentSelesai = 0,
    percentDitolak = 0,
    percentTingkatPenyelesaian = 0;

let initialTrendData: {
    labels?: string[];
    masuk?: number[];
    selesai?: number[];
    ditolak?: number[];
} | null = null;

if (trendRes.status === "fulfilled" && trendRes.value.ok) {
    try {
        const json = await trendRes.value.json();
        if (json.success && json.data) {
            initialTrendData = json.data;
            const {
                labels = [],
                masuk = [],
                selesai = [],
                ditolak = [],
            } = json.data as {
                labels?: string[];
                masuk?: number[];
                selesai?: number[];
                ditolak?: number[];
            };
            const currentIndex = findMonthIndex(labels, currentDate);
            const previousIndex = findMonthIndex(labels, previousDate);

            if (currentIndex >= 0) {
                currentTotal = masuk[currentIndex] ?? 0;
                currentSelesai = selesai[currentIndex] ?? 0;
                currentDitolak = ditolak[currentIndex] ?? 0;
                currentTingkatPenyelesaian = currentTotal
                    ? Math.round((currentSelesai / currentTotal) * 100)
                    : 0;
                currentLabel = labels[currentIndex] ?? currentLabel;
            }

            const previousTotal =
                previousIndex >= 0 ? (masuk[previousIndex] ?? 0) : 0;
            const previousSelesai =
                previousIndex >= 0 ? (selesai[previousIndex] ?? 0) : 0;
            const previousDitolak =
                previousIndex >= 0 ? (ditolak[previousIndex] ?? 0) : 0;
            const previousTingkatPenyelesaian = previousTotal
                ? Math.round((previousSelesai / previousTotal) * 100)
                : 0;

            if (previousIndex >= 0) {
                previousLabel = labels[previousIndex] ?? previousLabel;
            }

            percentTotal = calcPct(currentTotal, previousTotal);
            percentSelesai = calcPct(currentSelesai, previousSelesai);
            percentDitolak = calcPct(currentDitolak, previousDitolak);
            percentTingkatPenyelesaian = calcPct(
                currentTingkatPenyelesaian,
                previousTingkatPenyelesaian,
            );
        }
    } catch {}
}

function mapRiwayatItems(items: any[]) {
    return items.map((item: any) => ({
        kode: item.id,
        tanggal: new Date(item.submittedAt).toLocaleDateString("id-ID", {
            day: "numeric",
            month: "long",
            year: "numeric",
        }),
        status: item.status,
        title: item.serviceTitle ?? "",
        iconBody: item.icon ?? "",
    }));
}

let initialRiwayatByStatus: Record<string, any[]> = {};
if (riwayatDiprosesRes.status === "fulfilled" && riwayatDiprosesRes.value.ok) {
    try {
        const json = await riwayatDiprosesRes.value.json();
        initialRiwayatByStatus = {
            ...initialRiwayatByStatus,
            Diproses: mapRiwayatItems(json.data ?? []),
        };
    } catch {}
}
if (riwayatSelesaiRes.status === "fulfilled" && riwayatSelesaiRes.value.ok) {
    try {
        const json = await riwayatSelesaiRes.value.json();
        initialRiwayatByStatus = {
            ...initialRiwayatByStatus,
            Selesai: mapRiwayatItems(json.data ?? []),
        };
    } catch {}
}

let initialSurveyData: any[] | null = null;
if (surveyRes.status === "fulfilled" && surveyRes.value.ok) {
    try {
        const json = await surveyRes.value.json();
        if (json.success !== false && Array.isArray(json.data)) {
            initialSurveyData = json.data;
        }
    } catch {}
}

let initialKategoriPopuler: any[] | null = null;
if (kategoriPopulerRes.status === "fulfilled" && kategoriPopulerRes.value.ok) {
    try {
        const json = await kategoriPopulerRes.value.json();
        if (Array.isArray(json.data)) {
            initialKategoriPopuler = json.data;
        }
    } catch {}
}

function trendTone(percentage: number, positiveIsGood = true): string {
    const improves = percentage >= 0;
    if (percentage === 0) return "bg-black/6 text-gray-600";
    return improves === positiveIsGood
        ? "bg-green/10 text-green"
        : "bg-red-100 text-red-600";
}

function trendIcon(percentage: number): string {
    return percentage >= 0 ? "mdi:arrow-top-right" : "mdi:arrow-bottom-right";
}

const cardData = [
    {
        title: "Total Layanan Masuk",
        value: currentTotal.toLocaleString("id-ID"),
        percentage: percentTotal,
        positiveIsGood: true,
        icon: "mdi:file-document-multiple-outline",
        note: `${currentLabel} vs ${previousLabel}`,
    },
    {
        title: "Permohonan Selesai",
        value: currentSelesai.toLocaleString("id-ID"),
        percentage: percentSelesai,
        positiveIsGood: true,
        icon: "mdi:check-all",
        note: `${currentLabel} vs ${previousLabel}`,
    },
    {
        title: "Permohonan Ditolak",
        value: currentDitolak.toLocaleString("id-ID"),
        percentage: percentDitolak,
        positiveIsGood: false,
        icon: "mdi:file-document-remove-outline",
        note: `${currentLabel} vs ${previousLabel}`,
    },
    {
        title: "Tingkat Penyelesaian",
        value: `${currentTingkatPenyelesaian.toLocaleString("id-ID")}%`,
        percentage: percentTingkatPenyelesaian,
        positiveIsGood: true,
        icon: "mdi:chart-donut",
        note: `${currentLabel} vs ${previousLabel}`,
    },
];
---

<BaseLayout title="Informasi Layanan">
    <!-- Judul -->
    <section class="my-6 md:my-12 overflow-hidden">
        <div
            class="hero-label font-semibold mb-2 bg-yellow w-fit px-3 md:px-4 py-1.5 md:py-2 uppercase text-xs md:text-sm tracking-wide"
        >
            Dashboard Layanan Publik
        </div>
        <h1
            class="hero-title text-4xl sm:text-5xl md:text-7xl font-bold uppercase tracking-tight leading-none"
        >
            Informasi Layanan
        </h1>
        <h3
            class="hero-sub text-base sm:text-xl md:text-3xl font-semibold mt-3 md:mt-4"
        >
            <span class="text-green">Transparan. Akuntabel.</span> Untuk Pelayanan
            yang Lebih Baik.
        </h3>
        <p
            class="hero-desc text-sm md:text-lg text-gray-600 mt-2 md:mt-4 max-w-lg"
        >
            Pantau data layanan, proses, penyelesaian, dan hasil survey
            masyarakat secara real-time dan transparan.
        </p>
    </section>

    <!-- Card Informasi -->
    <section
        class="grid grid-cols-1 sm:grid-cols-2 2xl:grid-cols-4 gap-3 md:gap-5"
    >
        {
            cardData.map((card, index) => (
                <div
                    class="p-4 md:p-6 border shadow-sm rounded-lg flex items-center gap-3 md:gap-5 card-enter group hover:shadow-md hover:-translate-y-1 transition-all duration-300 cursor-default"
                    style={`animation-delay:${index * 0.12}s`}
                >
                    <div
                        class={`w-14 h-14 md:w-20 md:h-20 shrink-0 rounded-lg ${index === 2 ? "bg-red-400" : index === 3 ? "bg-yellow" : "bg-green"} flex items-center justify-center transition-transform duration-300 group-hover:scale-110`}
                    >
                        <Icon
                            name={card.icon}
                            class={`${index === 3 ? "text-black" : "text-white"}`}
                            width="26"
                            height="26"
                        />
                    </div>
                    <div class="min-w-0">
                        <h3 class="text-sm md:text-xl font-bold uppercase">
                            {card.title}
                        </h3>
                        <div class="flex items-center gap-3 md:gap-5 mt-1 md:mt-2">
                            <p class="text-2xl md:text-4xl font-bold">
                                {card.value}
                            </p>
                            <p
                                class={`text-xs md:text-sm flex items-center gap-1 ${trendTone(card.percentage ?? 0, card.positiveIsGood)} rounded-full py-1 px-2 md:px-3 font-semibold`}
                            >
                                <Icon
                                    name={trendIcon(card.percentage ?? 0)}
                                    width="14"
                                    height="14"
                                />
                                {Math.abs(card.percentage ?? 0)}%
                            </p>
                        </div>
                        <p class="text-xs md:text-sm text-gray-600 mt-0.5">
                            {card.note}
                        </p>
                    </div>
                </div>
            ))
        }
    </section>

    <InformationCategoryStats server:defer>
        <div
            slot="fallback"
            class="my-3 md:my-5 border rounded-lg p-4 md:p-5 animate-pulse"
        >
            <div class="h-6 w-48 bg-gray-200 rounded mb-3"></div>
            <div class="h-4 w-80 max-w-full bg-gray-100 rounded mb-5"></div>
            <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-3">
                {
                    Array.from({ length: 3 }).map(() => (
                        <div class="border border-black/10 rounded-lg p-4 space-y-4">
                            <div class="h-5 w-2/3 bg-gray-200 rounded" />
                            <div class="h-2.5 w-full bg-gray-100 rounded-full" />
                            <div class="grid grid-cols-3 gap-2">
                                <div class="h-12 bg-gray-100 rounded" />
                                <div class="h-12 bg-gray-100 rounded" />
                                <div class="h-12 bg-gray-100 rounded" />
                            </div>
                        </div>
                    ))
                }
            </div>
        </div>
    </InformationCategoryStats>

    <!-- Statistik -->
    <section
        class="grid grid-cols-1 md:grid-cols-5 gap-3 md:gap-5 my-3 md:my-5"
    >
        <div class="md:col-span-3 h-full">
            <TrendLayanan
                apiUrl="/api/trend"
                initialPeriod="3 Bulan"
                initialData={initialTrendData}
                client:visible
            />
        </div>
        <div class="md:col-span-2 h-full">
            <RiwayatLayanan
                apiUrl="/api/riwayat"
                initialDataByStatus={initialRiwayatByStatus}
                client:visible
            />
        </div>
    </section>

    <section
        class="my-3 md:my-5 grid grid-cols-1 md:grid-cols-5 gap-3 md:gap-5"
    >
        <div class="md:col-span-5 h-full border rounded-lg p-4 md:p-5">
            <div class="flex items-center gap-2 md:gap-3 mb-3">
                <Icon
                    name="mdi:thumb-up"
                    width="18"
                    height="18"
                    fill="#FBBF24"
                />
                <h2
                    class="font-bold uppercase text-sm md:text-xl tracking-tight"
                >
                    Nilai Survei Layanan Publik
                </h2>
            </div>
            <KepuasanMasyarakat
                apiUrl="/api/survei/public-averages?period=12"
                initialData={initialSurveyData}
                client:visible
            />
        </div>
        <div class="md:col-span-5 h-full border rounded-lg p-4 md:p-5">
            <h2
                class="font-bold uppercase text-sm md:text-xl tracking-tight mb-3"
            >
                Kategori Layanan Terpopuler
            </h2>
            <KategoriPopuler
                apiUrl="/api/kategori-populer"
                initialData={initialKategoriPopuler}
                client:visible
            />
        </div>
    </section>

    <!-- Zona Integritas -->
    <div
        class="border border-green bg-green/10 p-4 flex items-center justify-between gap-3 my-3 md:my-5"
    >
        <div>
            <p
                class="text-lg md:text-2xl font-bold uppercase tracking-wide text-green"
            >
                Zona Integritas
            </p>
            <p class="text-sm md:text-base opacity-80 mt-0.5">
                Kantor Kementerian Agama Kota Probolinggo berkomitmen memberikan
                pelayanan prima menuju Wilayah Bebas dari Korupsi (WBK) dan
                Wilayah Birokrasi Bersih dan Melayani (WBBM).
            </p>

            <a
                href="/pengaduan"
                class="text-green text-sm font-semibold mt-1 inline-block hover:underline"
            >
                Laporkan Penyelewengan →
            </a>
        </div>
        <div
            class="w-14 h-14 md:w-20 md:h-20 bg-green/10 rounded-full flex items-center justify-center animate-pulse shrink-0"
            style="color:#0F6B44"
        >
            <Icon
                name="mdi:shield-check"
                class="text-green"
                width="26"
                height="26"
            />
        </div>
    </div>
</BaseLayout>

<style>
    @keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
    @keyframes fadeIn {
        from {
            opacity: 0;
        }
        to {
            opacity: 1;
        }
    }
    @keyframes slideRight {
        from {
            opacity: 0;
            transform: translateX(-24px);
        }
        to {
            opacity: 1;
            transform: translateX(0);
        }
    }

    .card-enter {
        opacity: 0;
        animation: slideUp 0.45s ease forwards;
    }

    .hero-label {
        opacity: 0;
        animation: slideRight 0.5s ease forwards 0.05s;
    }
    .hero-title {
        opacity: 0;
        animation: slideRight 0.55s ease forwards 0.15s;
    }
    .hero-sub {
        opacity: 0;
        animation: slideRight 0.55s ease forwards 0.28s;
    }
    .hero-desc {
        opacity: 0;
        animation: slideRight 0.5s ease forwards 0.4s;
    }
</style>
