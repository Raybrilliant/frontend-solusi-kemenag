---
import Hero from "../components/Hero.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import Layanan from "../components/Layanan.astro";
import TikTokVideos from "../components/Svelte/TikTokVideos.svelte";

const SITE_URL = "https://kemenagkotaprobolinggo.id";
const BACKEND_URL = process.env.BACKEND_URL ?? "http://localhost:3000";

// Fetch testimoni aktif dari backend saat SSR
let testimoniVideos = [];
try {
    const res = await fetch(`${BACKEND_URL}/api/v1/testimoni/`, {
        signal: AbortSignal.timeout(8000),
    });
    if (res.ok) {
        const json = await res.json();
        if (json.success === true && Array.isArray(json.data)) {
            testimoniVideos = json.data.map((item: any) => ({
                id: String(item.id),
                url: item.url,
                title: item.title,
                username: item.username,
            }));
        }
    }
} catch (e) {
    console.warn(
        "[index] Gagal memuat testimoni dari backend:",
        (e as Error).message,
    );
}

Astro.response.headers.set(
    "Cache-Control",
    "public, max-age=300, stale-while-revalidate=600",
);
const structuredData = [
    {
        "@context": "https://schema.org",
        "@type": "GovernmentOrganization",
        name: "Kantor Kementerian Agama Kota Probolinggo",
        url: SITE_URL,
        logo: `${SITE_URL}/logo.png`,
        image: `${SITE_URL}/logo.png`,
        areaServed: "Kota Probolinggo",
        sameAs: [
            "https://www.instagram.com/kemenagkoprob/",
            "https://www.facebook.com/kemenagkoprob/",
        ],
    },
    {
        "@context": "https://schema.org",
        "@type": "WebSite",
        name: "Kemenag Kota Probolinggo",
        url: SITE_URL,
        inLanguage: "id-ID",
    },
];
---

<BaseLayout
    title="Layanan Publik & Portal Resmi"
    description="Portal resmi Kantor Kementerian Agama Kota Probolinggo untuk layanan publik, berita, regulasi, pengaduan, dan informasi layanan terintegrasi."
    ogTitle="Portal Resmi Kemenag Kota Probolinggo"
    ogDescription="Akses layanan publik, berita resmi, regulasi, pengaduan, dan informasi layanan Kementerian Agama Kota Probolinggo dalam satu portal."
    structuredData={structuredData}
>
    <Hero />
    <Layanan />
    <TikTokVideos videos={testimoniVideos} client:visible />
</BaseLayout>
