---
import { Icon } from "astro-icon/components";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { toUploadProxyUrl } from "../../lib/upload-url";
import { categoryColor, categoryAccent } from "../../lib/berita-kategori";


const BACKEND_URL = process.env.BACKEND_URL ?? "http://localhost:3000";

// Hierarchy order — strongest to weakest
const TYPE_ORDER = [
    "UU", "PERPU", "PP", "PERPRES", "INPRES",
    "PERMEN", "PMA", "KMA", "PERDIRJEN", "SE", "SKB",
];

// Fetch berita (6 terbaru) dan regulasi secara paralel
const [beritaRaw, regulasiRaw] = await Promise.allSettled([
    fetch(`${BACKEND_URL}/api/v1/berita/?limit=6`).then(r => r.ok ? r.json() : { data: [] }),
    fetch(`${BACKEND_URL}/api/v1/regulasi/?limit=100`).then(r => r.ok ? r.json() : { data: [] }),
]);

const berita = ((beritaRaw.status === "fulfilled" ? beritaRaw.value?.data : null) ?? [])
    .map((b: any) => ({
        ...b,
        thumbnail: toUploadProxyUrl(b.thumbnail) || b.thumbnail,
    }));

const regulasiAll = ((regulasiRaw.status === "fulfilled" ? regulasiRaw.value?.data : null) ?? [])
    .map((r: any) => ({ ...r, fileUrl: toUploadProxyUrl(r.fileUrl) || r.fileUrl }));

// Sort by legal hierarchy then take 6
const regulasi = [...regulasiAll].sort((a: any, b: any) => {
    const ai = TYPE_ORDER.indexOf((a.type ?? "").toUpperCase());
    const bi = TYPE_ORDER.indexOf((b.type ?? "").toUpperCase());
    if (ai === -1 && bi === -1) return 0;
    if (ai === -1) return 1;
    if (bi === -1) return -1;
    return ai - bi;
}).slice(0, 6);

function formatDate(dateStr: string | null) {
    if (!dateStr) return "";
    return new Date(dateStr).toLocaleDateString("id-ID", {
        day: "numeric", month: "long", year: "numeric",
    });
}

// Fetch semua kategori unik dari berita yang ada
let rawKategori: string[] = [];
try {
    const katRes = await fetch(`${BACKEND_URL}/api/v1/berita/?limit=500`);
    if (katRes.ok) {
        const katData = await katRes.json();
        rawKategori = [
            ...new Set(
                (katData?.data ?? [])
                    .map((b: any) => (b.kategori ?? "").trim().toLowerCase())
                    .filter(Boolean),
            ),
        ].sort();
    }
} catch {}


function regulasiBadge(type: string) {
    const t = type.toUpperCase();
    switch (t) {
        case "PMA":
        case "PERMEN":  return "bg-green/20 text-green";
        case "KMA":     return "bg-yellow/20 text-yellow";
        case "PP":
        case "PERPRES":
        case "INPRES":  return "bg-white/15 text-white/70";
        case "UU":
        case "PERPU":   return "bg-white/20 text-white";
        default:        return "bg-white/10 text-white/50";
    }
}
---

<style is:global>
    /*
     * Extend hero dark background up into the navbar area.
     * Navbar gets full-bleed (mirrors body padding as negative margin)
     * so the dark bg covers the full page width — no cream strips on sides.
     * Only the navbar + hero are dark; everything else stays cream (global CSS).
     */
    body:has(#hero-section) #site-header {
        background-color: #0a1a0c;
        color: white;
        /* full-bleed: cancel out body padding (px-4) */
        margin-left: -1rem;
        margin-right: -1rem;
        padding-left: 1rem;
        padding-right: 1rem;
    }
    @media (min-width: 640px) {
        body:has(#hero-section) #site-header {
            margin-left: -2rem;
            margin-right: -2rem;
            padding-left: 2rem;
            padding-right: 2rem;
        }
    }
    @media (min-width: 768px) {
        body:has(#hero-section) #site-header {
            margin-left: -3.5rem;
            margin-right: -3.5rem;
            padding-left: 3.5rem;
            padding-right: 3.5rem;
        }
    }
    @media (min-width: 1024px) {
        body:has(#hero-section) #site-header {
            margin-left: -5rem;
            margin-right: -5rem;
            padding-left: 5rem;
            padding-right: 5rem;
        }
    }
    body:has(#hero-section) #site-header .ham-line {
        background-color: white;
    }
    /* Keep ASN button text dark (readable on yellow bg) */
    body:has(#hero-section) #site-header .btn-asn {
        color: #111111;
    }
    /* Mobile drawer dark bg */
    body:has(#hero-section) #mobile-menu {
        background-color: #0b1e0d;
    }
    body:has(#hero-section) #mobile-menu .border-t {
        border-color: rgba(255, 255, 255, 0.08);
    }
    body:has(#hero-section) #mobile-menu a:not(.btn-asn) {
        color: rgba(255, 255, 255, 0.6);
    }
    body:has(#hero-section) #mobile-menu a:not(.btn-asn):hover {
        color: white;
        background-color: rgba(255, 255, 255, 0.06);
    }
    body:has(#hero-section) #mobile-menu a.text-green {
        color: #0f6b44;
    }
</style>

<style>
    /* ── Dot grid hero ───────────────────────────────────── */
    .hero-dots {
        background-image: radial-gradient(
            circle,
            rgba(255, 255, 255, 0.16) 1px,
            transparent 1px
        );
        background-size: 28px 28px;
    }

    /* ── Scroll hint bounce ──────────────────────────────── */
    @keyframes bounce-y {
        0%,
        100% { transform: translateY(0); }
        50%   { transform: translateY(6px); }
    }
    .bounce-arrow { animation: bounce-y 1.6s ease-in-out infinite; }

    /* ── Hero entrance animations ────────────────────────── */
    [data-hero="badge"]   { animation: fadeDown 0.6s cubic-bezier(0.16,1,0.3,1) 0.1s  both; }
    [data-hero="h1"]      { animation: fadeUp   0.8s cubic-bezier(0.16,1,0.3,1) 0.2s  both; }
    [data-hero="sub"]     { animation: fadeUp   0.7s cubic-bezier(0.16,1,0.3,1) 0.35s both; }
    [data-hero="hint"]    { animation: fadeUp   0.6s cubic-bezier(0.16,1,0.3,1) 0.5s  both; }

    /* ── Scroll reveal ───────────────────────────────────── */
    [data-reveal] {
        opacity: 0;
        transition: opacity 0.7s cubic-bezier(0.16,1,0.3,1),
                    transform 0.7s cubic-bezier(0.16,1,0.3,1);
        will-change: transform, opacity;
    }
    [data-reveal="up"]   { transform: translateY(32px); }
    [data-reveal="left"] { transform: translateX(-32px); }
    [data-reveal].revealed { opacity: 1; transform: none; }
    [data-delay="1"] { transition-delay: 0.08s; }
    [data-delay="2"] { transition-delay: 0.16s; }
    [data-delay="3"] { transition-delay: 0.24s; }
    [data-delay="4"] { transition-delay: 0.32s; }
    [data-delay="5"] { transition-delay: 0.40s; }
    [data-delay="6"] { transition-delay: 0.48s; }

    @keyframes fadeDown {
        from { opacity: 0; transform: translateY(-14px); }
        to   { opacity: 1; transform: translateY(0); }
    }
    @keyframes fadeUp {
        from { opacity: 0; transform: translateY(24px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    /* ── News card hover ─────────────────────────────────── */
    .news-card {
        transition: transform 0.25s ease, box-shadow 0.25s ease;
    }
    .news-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 32px rgba(0,0,0,0.1);
    }
</style>

