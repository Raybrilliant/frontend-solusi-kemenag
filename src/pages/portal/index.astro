<script>
{
    // ── Parallax scroll ───────────────────────────────────
    const section = document.getElementById("hero-section") as HTMLElement | null;
    const img     = document.getElementById("parallax-img") as HTMLImageElement | null;
    const hint    = document.getElementById("scroll-hint") as HTMLElement | null;

    function updateParallax() {
        if (!section || !img) return;
        const rect       = section.getBoundingClientRect();
        const scrolled   = Math.max(0, -rect.top);
        const scrollable = section.offsetHeight - window.innerHeight;
        const progress   = scrollable > 0 ? Math.min(1, scrolled / scrollable) : 0;

        // Image rises from 65% of viewport height → 0
        const startY = window.innerHeight * 0.65;
        img.style.transform = `translateY(${startY * (1 - progress)}px)`;

        // Scroll hint fades out quickly as user scrolls
        if (hint) hint.style.opacity = String(Math.max(0, 1 - progress * 8));
    }

    // ── Scroll reveal ─────────────────────────────────────
    const revealObs = new IntersectionObserver(
        (entries) => {
            entries.forEach((e) => {
                if (e.isIntersecting) {
                    e.target.classList.add("revealed");
                    revealObs.unobserve(e.target);
                }
            });
        },
        { threshold: 0.1, rootMargin: "0px 0px -40px 0px" }
    );

    function init() {
        window.addEventListener("scroll", updateParallax, { passive: true });
        window.addEventListener("resize", updateParallax);
        updateParallax();
        document.querySelectorAll("[data-reveal]").forEach((el) => revealObs.observe(el));
    }

    init();
    document.addEventListener("astro:page-load", () => {
        window.removeEventListener("scroll", updateParallax);
        window.removeEventListener("resize", updateParallax);
        init();
    });
}
</script>
