                class="text-3xl sm:text-4xl font-extrabold uppercase tracking-tight text-ink">
                Arah &amp; Komitmen Kami
            </h2>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-5 gap-8 lg:gap-14">

            <!-- Visi -->
            <div data-reveal="up" class="lg:col-span-2">
                <div class="flex items-center gap-2 mb-5">
                    <div class="w-1 h-5 bg-yellow shrink-0"></div>
                    <span class="text-[11px] font-black uppercase tracking-[0.18em] text-yellow">Visi</span>
                </div>
                <div class="relative border-l-2 border-yellow pl-5">
                    <p class="text-base sm:text-lg font-bold text-ink leading-relaxed">
                        "Terwujudnya Masyarakat yang Rukun, Maslahat, dan Cerdas
                        Bersama Indonesia Maju Menuju Indonesia Emas 2045"
                    </p>
                </div>
            </div>

            <!-- Misi -->
            <div data-reveal="up" data-delay="1" class="lg:col-span-3">
                <div class="flex items-center gap-2 mb-5">
                    <div class="w-1 h-5 bg-green shrink-0"></div>
                    <span class="text-[11px] font-black uppercase tracking-[0.18em] text-green">Misi</span>
                </div>
                <ol class="space-y-3">
                    {misi.map((m, i) => (
                        <li class="flex items-start gap-3">
                            <span class="shrink-0 w-6 h-6 bg-ink text-cream text-[11px] font-black flex items-center justify-center mt-0.5">
                                {i + 1}
                            </span>
                            <span class="text-sm text-ink/70 leading-relaxed pt-0.5">{m}</span>
                        </li>
                    ))}
                </ol>
            </div>
        </div>
    </section>

    <!-- ══════════════════════════════════════════════════════ -->
    <!-- STRUKTUR ORGANISASI -->
    <!-- ══════════════════════════════════════════════════════ -->
    <section id="struktur-organisasi" class="section-anchor py-16">

        <div class="mb-10">
            <div data-reveal="up" class="flex items-center gap-3 mb-3">
                <div class="w-1 h-6 bg-green"></div>
                <span class="text-[11px] font-black uppercase tracking-[0.18em] text-green">Struktur Organisasi</span>
            </div>
            <h2 data-reveal="up" data-delay="1"
                class="text-3xl sm:text-4xl font-extrabold uppercase tracking-tight text-ink mb-3">
                Pejabat &amp; Unit Kerja
            </h2>
            <p data-reveal="up" data-delay="2"
               class="text-sm text-ink/50 max-w-lg leading-relaxed">
                Klik pada kartu pejabat untuk melihat uraian tugas dan fungsi jabatan.
            </p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {struktur.map((p, i) => (
                <button
                    type="button"
                    data-reveal="up"
                    data-delay={String((i % 3) + 1)}
                    class="pejabat-card text-left border border-ink/10 bg-cream p-5 flex items-start gap-4 w-full group cursor-pointer focus:outline-none focus:ring-2 focus:ring-green/30"
                    data-pejabat={JSON.stringify({ nama: p.nama, jabatan: p.jabatan, foto: p.foto, ringkasan: p.ringkasan, tugasFungsi: p.tugasFungsi })}
                    role="button"
                    tabindex="0"
                >
                    <!-- Photo placeholder -->
                    <div class="w-16 h-20 shrink-0 bg-ink/5 border border-ink/8 flex items-center justify-center group-hover:bg-green/8 group-hover:border-green/20 transition-colors">
                        <img src={p.foto} alt={p.nama} class="w-full h-full object-cover" />
                    </div>

                    <div class="flex-1 min-w-0">
                        <span class="text-[10px] font-black uppercase tracking-wider text-green/70 block mb-1 group-hover:text-green transition-colors">
                            {p.jabatan}
                        </span>
                        <h3 class="text-sm font-bold text-ink leading-snug mb-3 group-hover:text-ink transition-colors">
                            {p.nama}
                        </h3>
                        <span class="inline-flex items-center gap-1.5 text-[10px] font-bold uppercase tracking-wider text-ink/30 group-hover:text-green transition-colors">
                            <svg viewBox="0 0 24 24" width="11" height="11" fill="currentColor">
                                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/>
                            </svg>
                            Tugas &amp; Fungsi
                        </span>
                    </div>

                    <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor"
                         class="shrink-0 text-ink/15 group-hover:text-green/50 transition-colors mt-1">
                        <path d="M8.59 16.59 13.17 12 8.59 7.41 10 6l6 6-6 6-1.41-1.41z"/>
                    </svg>
                </button>
            ))}
        </div>
    </section>

    <!-- ══ MODAL TUGAS & FUNGSI ══════════════════════════════ -->
<div id="modal-overlay"
     class="modal-hidden fixed inset-0 z-50 flex items-end sm:items-center justify-center p-0 sm:p-6 pointer-events-none"
     aria-modal="true" role="dialog" aria-labelledby="modal-nama">

    <!-- Backdrop -->
    <div class="modal-backdrop absolute inset-0 bg-ink/60 backdrop-blur-sm cursor-pointer pointer-events-auto"
         id="modal-backdrop"></div>

    <!-- Panel -->
    <div class="modal-panel relative bg-cream w-full sm:max-w-lg max-h-[88vh] sm:max-h-[80vh] overflow-y-auto shadow-2xl pointer-events-auto">

        <!-- Close -->
        <button id="modal-close"
                class="absolute top-4 right-4 w-8 h-8 flex items-center justify-center border border-ink/15 text-ink/40 hover:border-ink/40 hover:text-ink transition-colors z-10"
                aria-label="Tutup">
            <svg viewBox="0 0 24 24" width="15" height="15" fill="currentColor">
                <path d="M19 6.41 17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/>
            </svg>
        </button>

        <div class="p-6 sm:p-8">

            <!-- Header profil -->
            <div class="mb-6 pr-10 text-center">
                <p id="modal-jabatan" class="text-[11px] font-black uppercase tracking-wider text-green mb-2"></p>
                <h2 id="modal-nama" class="text-xl sm:text-2xl font-extrabold text-ink leading-snug max-w-md mx-auto"></h2>

                <div class="mt-5 flex justify-center">
                    <div class="w-28 h-36 sm:w-32 sm:h-40 bg-ink/5 border border-ink/8 overflow-hidden rounded-xl shadow-sm">
                        <img
                            id="modal-foto"
                            src="/kepala-kantor/DIDIK.webp"
                            alt="Foto pejabat"
                            class="w-full h-full object-cover"
                        />
                    </div>
                </div>
            </div>

    
                <p class="text-[11px] font-black uppercase tracking-wider text-ink/35 mb-2">
                    Ringkasan Profil
                </p>
                <p id="modal-ringkasan" class="text-sm text-ink/70 text-justify leading-relaxed mb-3"></p>

            <div class="border-t border-ink/8 mb-5"></div>

            <!-- Tugas & Fungsi -->
            <h3 class="text-[11px] font-black uppercase tracking-wider text-ink/35 mb-3">
                Tugas &amp; Fungsi
            </h3>
            <ul id="modal-tugas" class="space-y-2.5"></ul>
        </div>
    </div>
</div>

</BaseLayout>

<script>
    type PejabatModalData = {
        nama?: string;
        jabatan?: string;
        foto?: string;
        ringkasan?: string;
        tugasFungsi?: string[];
    };

    function initProfilPage() {
        const overlayEl = document.getElementById("modal-overlay");
        const backdropEl = document.getElementById("modal-backdrop");
        const closeBtnEl = document.getElementById("modal-close");
        const elNamaEl = document.getElementById("modal-nama");
        const elJabatanEl = document.getElementById("modal-jabatan");
        const elFotoEl = document.getElementById("modal-foto");
        const elRingkasanEl = document.getElementById("modal-ringkasan");
        const elTugasEl = document.getElementById("modal-tugas");

        if (
            !(overlayEl instanceof HTMLElement) ||
            !(backdropEl instanceof HTMLElement) ||
            !(closeBtnEl instanceof HTMLElement) ||
            !(elNamaEl instanceof HTMLElement) ||
            !(elJabatanEl instanceof HTMLElement) ||
            !(elFotoEl instanceof HTMLImageElement) ||
            !(elRingkasanEl instanceof HTMLElement) ||
            !(elTugasEl instanceof HTMLElement)
        ) {
            return;
        }

        const overlay = overlayEl;
        const backdrop = backdropEl;
        const closeBtn = closeBtnEl;
        const elNama = elNamaEl;
        const elJabatan = elJabatanEl;
        const elFoto = elFotoEl;
        const elRingkasan = elRingkasanEl;
        const elTugas = elTugasEl;

        let lastFocused: HTMLElement | null = null;

        function clearTugas() {
            while (elTugas.firstChild) {
                elTugas.removeChild(elTugas.firstChild);
            }
        }

        function openModal(data: PejabatModalData, trigger: HTMLElement) {
            lastFocused = trigger;
            elNama.textContent = data.nama ?? "";
            elJabatan.textContent = data.jabatan ?? "";
            elFoto.src = data.foto || "/kepala-kantor/DIDIK.webp";
            elFoto.alt = data.nama ? `Foto ${data.nama}` : "Foto pejabat";
            elRingkasan.textContent = data.ringkasan ?? "";

            clearTugas();
            (data.tugasFungsi ?? []).forEach((item: string) => {
                const li = document.createElement("li");
                li.className = "flex items-start gap-2.5";

                const dot = document.createElement("span");
                dot.className = "shrink-0 w-1.5 h-1.5 rounded-full bg-green mt-[6px]";

                const text = document.createElement("span");
                text.className = "text-sm text-ink/70 leading-relaxed";
                text.textContent = item;

                li.append(dot, text);
                elTugas.appendChild(li);
            });

            overlay.classList.remove("modal-hidden");
            overlay.style.pointerEvents = "auto";
            document.body.style.overflow = "hidden";
            closeBtn.focus();
        }

        function closeModal() {
            overlay.classList.add("modal-hidden");
            overlay.style.pointerEvents = "none";
            document.body.style.overflow = "";
            lastFocused?.focus();
        }

        document
            .querySelectorAll<HTMLButtonElement>("[data-pejabat]")
            .forEach((card) => {
                if (card.dataset.modalBound === "true") return;
                card.dataset.modalBound = "true";

                const trigger = card;
                const handleOpen = () => {
                    try {
                        const data = JSON.parse(
                            trigger.dataset.pejabat || "{}",
                        ) as PejabatModalData;
                        openModal(data, trigger);
                    } catch (error) {
                        console.error("Gagal membuka modal pejabat:", error);
                    }
                };

                trigger.addEventListener("click", handleOpen);
                trigger.addEventListener("keydown", (event: KeyboardEvent) => {
                    if (event.key === "Enter" || event.key === " ") {
                        event.preventDefault();
                        handleOpen();
                    }
                });
            });

        if (backdrop.dataset.modalBound !== "true") {
            backdrop.dataset.modalBound = "true";
            backdrop.addEventListener("click", closeModal);
        }

        if (closeBtn.dataset.modalBound !== "true") {
            closeBtn.dataset.modalBound = "true";
            closeBtn.addEventListener("click", closeModal);
        }

        if (document.body.dataset.profilEscapeBound !== "true") {
            document.body.dataset.profilEscapeBound = "true";
            document.addEventListener("keydown", (event: KeyboardEvent) => {
                if (event.key === "Escape") closeModal();
            });
        }

        const obs = new IntersectionObserver(
            (entries) =>
                entries.forEach((entry) => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add("revealed");
                        obs.unobserve(entry.target);
                    }
                }),
            { threshold: 0.1, rootMargin: "0px 0px -30px 0px" },
        );
        document.querySelectorAll("[data-reveal]").forEach((el) => obs.observe(el));
    }

    initProfilPage();
    document.addEventListener("astro:page-load", initProfilPage);
</script>
