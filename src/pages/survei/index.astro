---
import BaseLayout from "../../layouts/BaseLayout.astro";
import FormSurvei from "../../components/Svelte/FormSurvei.svelte";

const ticket =
    Astro.url.searchParams.get("ticket") ??
    Astro.url.searchParams.get("kode") ??
    "";
---

<style>
    [data-anim="badge"] {
        animation: slideDown 0.5s cubic-bezier(0.16, 1, 0.3, 1) 0.05s both;
    }
    [data-anim="heading"] {
        animation: slideUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.15s both;
    }
    [data-anim="desc"] {
        animation: slideUp 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.3s both;
    }
    [data-anim="form"] {
        animation: slideUp 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.45s both;
    }

    @keyframes slideDown {
        from {
            opacity: 0;
            transform: translateY(-14px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
    @keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(28px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<BaseLayout title="Survei Layanan">
    <section class="py-8 md:py-16 flex flex-col gap-5 md:gap-8">
        <div>
            <div
                data-anim="badge"
                class="font-semibold mb-2 bg-yellow w-fit px-3 md:px-4 py-1.5 md:py-2 uppercase text-xs md:text-sm tracking-wide"
            >
                Survei Layanan Publik
            </div>
            <h1
                data-anim="heading"
                class="text-3xl sm:text-4xl md:text-5xl font-bold mb-2 md:mb-3 uppercase"
            >
                Beri Nilai Layanan Anda
            </h1>
            <p
                data-anim="desc"
                class="text-sm md:text-base opacity-70 max-w-2xl"
            >
                Survei hanya dapat diisi setelah status layanan selesai. Isi
                berurutan mulai dari SPKP, lalu SPAK.
            </p>
        </div>

        <div data-anim="form">
            <FormSurvei client:load initialTicket={ticket} />
        </div>
    </section>
</BaseLayout>
