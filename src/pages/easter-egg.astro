---
export const prerender = true;

import BaseLayout from "../layouts/BaseLayout.astro";

const team = [
    {
        name: "Raihan Fikri Brilliansyach",
        role: "Pranata Komputer",
        photo: "/easter-egg/rey.webp", // ganti dengan path foto: "/pejabat-struktural/nama.jpg"
        bio: "Bertanggung jawab atas pengembangan sistem dan infrastruktur digital Kemenag Kota Probolinggo.",
        funFacts: [
            "Ngoding lebih dari 1000 jam buat portal ini",
            "Full DJ Angkot biar tetep strong",
            "Hari-hari debugging sampai subuh",
            "Sudah biasa bekerja dibawah tekanan sampe gepeng",
        ],
        linkedin: "https://www.linkedin.com/in/raybrilliant",  // "https://linkedin.com/in/username"
        github: "https://github.com/Raybrilliant",    // "https://github.com/username"
        portfolio: "https://raybrilliant.my.id", // "https://website-portfolio-anda.com"
    },
    // tambah anggota tim lain di sini dengan format yang sama
];
---

<style is:global>
    body:has(#hero-section) #site-header {
        background-color: #0a1a0c;
        color: white;
        margin-left: -1rem;   margin-right: -1rem;
        padding-left: 1rem;   padding-right: 1rem;
    }
    @media (min-width: 640px) {
        body:has(#hero-section) #site-header {
            margin-left: -2rem;   margin-right: -2rem;
            padding-left: 2rem;   padding-right: 2rem;
        }
    }
    @media (min-width: 768px) {
        body:has(#hero-section) #site-header {
            margin-left: -3.5rem; margin-right: -3.5rem;
            padding-left: 3.5rem; padding-right: 3.5rem;
        }
    }
    @media (min-width: 1024px) {
        body:has(#hero-section) #site-header {
            margin-left: -5rem;   margin-right: -5rem;
            padding-left: 5rem;   padding-right: 5rem;
        }
    }
    body:has(#hero-section) #site-header .ham-line { background-color: white; }
    body:has(#hero-section) #site-header .btn-asn  { color: #111111; }
    body:has(#hero-section) #mobile-menu            { background-color: #0b1e0d; }
    body:has(#hero-section) #mobile-menu .border-t  { border-color: rgba(255,255,255,.08); }
    body:has(#hero-section) #mobile-menu a:not(.btn-asn)       { color: rgba(255,255,255,.6); }
    body:has(#hero-section) #mobile-menu a:not(.btn-asn):hover { color: white; background-color: rgba(255,255,255,.06); }
    body:has(#hero-section) #mobile-menu a.text-green          { color: #0f6b44; }
</style>

<style>
    @keyframes glitch1 {
        0%,100%{ clip-path:inset(0 0 95% 0); transform:translate(-4px,0); }
        20%    { clip-path:inset(60% 0 20% 0);transform:translate(4px,0);  }
        40%    { clip-path:inset(30% 0 50% 0);transform:translate(-2px,0); }
        60%    { clip-path:inset(80% 0 5%  0);transform:translate(3px,0);  }
        80%    { clip-path:inset(10% 0 70% 0);transform:translate(-3px,0); }
    }
    @keyframes glitch2 {
        0%,100%{ clip-path:inset(50% 0 30% 0);transform:translate(4px,0);  }
        25%    { clip-path:inset(5%  0 85% 0); transform:translate(-4px,0); }
        50%    { clip-path:inset(70% 0 10% 0); transform:translate(2px,0);  }
        75%    { clip-path:inset(20% 0 60% 0); transform:translate(-2px,0); }
    }
    .glitch { position: relative; display: inline-block; }
    .glitch::before,
    .glitch::after {
        content: attr(data-text);
        position: absolute;
        inset: 0;
        font: inherit;
        font-weight: inherit;
        letter-spacing: inherit;
    }
    .glitch::before { color:#F6C744; animation: glitch1 3s infinite steps(1); }
    .glitch::after  { color:#0F6B44; animation: glitch2 3s infinite steps(1); }

    @keyframes float {
        0%,100%{ transform:translateY(0) rotate(0deg);   opacity:.5; }
        50%    { transform:translateY(-20px) rotate(180deg); opacity:.9; }
    }
    .particle { animation: float var(--dur,4s) ease-in-out var(--delay,0s) infinite; }

    @keyframes hero-in {
        from { opacity:0; transform:translateY(-20px) scale(.95); }
        to   { opacity:1; transform:none; }
    }
    .hi  { animation: hero-in .7s cubic-bezier(.16,1,.3,1) both; }
    .hi2 { animation: hero-in .7s cubic-bezier(.16,1,.3,1) .15s both; }
    .hi3 { animation: hero-in .7s cubic-bezier(.16,1,.3,1) .3s both; }

    [data-reveal] {
        opacity: 0;
        transition: opacity .7s cubic-bezier(.16,1,.3,1),
                    transform .7s cubic-bezier(.16,1,.3,1);
    }
    [data-reveal="up"]   { transform: translateY(32px); }
    [data-reveal="scale"]{ transform: scale(.88); }
    [data-reveal].visible { opacity:1; transform:none; }
    [data-delay="1"]{ transition-delay:.1s; }
    [data-delay="2"]{ transition-delay:.2s; }
    [data-delay="3"]{ transition-delay:.3s; }
    [data-delay="4"]{ transition-delay:.4s; }

    .tilt-card {
        transition: transform .3s ease, box-shadow .3s ease;
    }
    .tilt-card:hover {
        transform: translateY(-6px) rotate(-.4deg);
        box-shadow: 0 20px 48px rgba(0,0,0,.12);
    }

    .scanlines::after {
        content:"";
        position:absolute; inset:0;
        background: repeating-linear-gradient(
            0deg, transparent, transparent 2px,
            rgba(0,0,0,.04) 2px, rgba(0,0,0,.04) 4px
        );
        pointer-events:none;
    }

    @keyframes pulse-ring {
        0%  { box-shadow:0 0 0 0 rgba(15,107,68,.4); }
        70% { box-shadow:0 0 0 12px rgba(15,107,68,0); }
        100%{ box-shadow:0 0 0 0 rgba(15,107,68,0); }
    }
    .photo-ring { animation: pulse-ring 2.5s ease-out infinite; }
</style>

<BaseLayout
    title="Easter Egg — Prakom Kemenag"
    description="Halaman rahasia tim Pranata Komputer Kemenag Kota Probolinggo."
    robots="noindex, nofollow, noarchive"
>

    <!-- ══ HERO ═══════════════════════════════════════ -->
    <div id="hero-section"
         class="-mx-4 sm:-mx-8 md:-mx-14 lg:-mx-20 relative overflow-hidden scanlines"
         style="background:#0a1a0c; min-height:100vh; display:flex; flex-direction:column; align-items:center; justify-content:center;">

        <!-- Floating particles -->
        {["★","◆","✦","▲","●","◇","✸","⬡"].map((s, i) => (
            <div class="particle absolute pointer-events-none select-none"
                 style={`left:${6+(i*13)%88}%;top:${5+(i*19)%82}%;--dur:${3+(i%4)}s;--delay:${(i*.35)%2}s;font-size:${10+(i%3)*7}px;opacity:.25;color:${i%2?"#F6C744":"#0F6B44"}`}>
                {s}
            </div>
        ))}

        <!-- Glow -->
        <div class="absolute top-1/4 left-1/3 w-80 h-80 rounded-full pointer-events-none"
             style="background:radial-gradient(circle,rgba(15,107,68,.3) 0%,transparent 70%);filter:blur(48px);"></div>
        <div class="absolute bottom-1/4 right-1/3 w-64 h-64 rounded-full pointer-events-none"
             style="background:radial-gradient(circle,rgba(246,199,68,.2) 0%,transparent 70%);filter:blur(40px);"></div>

        <div class="relative z-10 text-center px-6 py-24">

            <!-- Badge -->
            <div class="hi inline-flex items-center gap-2 mb-8 px-4 py-2 border border-green/30 bg-green/10">
                <span class="w-2 h-2 bg-green rounded-full animate-pulse"></span>
                <span class="text-[11px] font-bold text-green/80 uppercase tracking-[.2em]">Secret Page Unlocked</span>
            </div>

            <!-- Glitch title -->
            <div class="hi2">
                <h1 class="glitch text-6xl sm:text-8xl md:text-9xl font-black uppercase tracking-tighter text-white leading-none"
                    data-text="WHOOPS!">
                    WHOOPS!
                </h1>
            </div>

            <div class="hi2 mt-3">
                <p class="text-xl sm:text-2xl md:text-3xl font-extrabold uppercase tracking-widest text-yellow">
                    You Found an Easter Egg 🥚
                </p>
            </div>

            <div class="hi3 mt-6 max-w-lg mx-auto">
                <p class="text-sm text-white/40 leading-relaxed">
                    Selamat! Kamu menemukan halaman rahasia ini.<br/>
                    Kenalkan tim <strong class="text-white/70">Pranata Komputer</strong> yang
                    membangun portal digital Kemenag Kota Probolinggo dari nol.
                </p>
            </div>

            <div class="hi3 mt-10 flex flex-col items-center gap-2">
                <span class="text-[10px] font-semibold text-white/20 uppercase tracking-widest">Scroll ke bawah</span>
                <div class="w-px h-10 bg-gradient-to-b from-white/25 to-transparent"></div>
            </div>
        </div>
    </div>

    <!-- ══ TEAM ════════════════════════════════════════ -->
    <section class="py-20 md:py-28">

        <div data-reveal="up" class="mb-16 text-center">
            <div class="inline-flex items-center gap-3 mb-4">
                <div class="h-px w-10 bg-green/30"></div>
                <span class="text-[11px] font-black uppercase tracking-[.2em] text-green">The Makers</span>
                <div class="h-px w-10 bg-green/30"></div>
            </div>
            <h2 class="text-4xl sm:text-5xl font-extrabold uppercase tracking-tight text-ink">
                Tim Di Balik Layar
            </h2>
            <p class="text-sm text-ink/40 mt-3 max-w-md mx-auto leading-relaxed">
                Orang-orang yang rela begadang, overdosis americano, dan debugging tanpa henti.
            </p>
        </div>

        <div class={`grid gap-8 ${team.length === 1 ? "max-w-md mx-auto" : team.length === 2 ? "sm:grid-cols-2 max-w-2xl mx-auto" : "sm:grid-cols-2 lg:grid-cols-3"}`}>
            {team.map((m, i) => (
                <div data-reveal="up" data-delay={String((i%3)+1)}
                     class="tilt-card bg-cream border border-ink/10 overflow-hidden">

                    <div class="h-1 w-full bg-green"></div>

                    <div class="p-7">

                        <!-- Photo -->
                        <div class="flex justify-center mb-6">
                            {m.photo ? (
                                <div class="photo-ring w-28 h-28 rounded-full overflow-hidden border-4 border-green/25">
                                    <img src={m.photo} alt={m.name}
                                         class="w-full h-full object-cover object-center" />
                                </div>
                            ) : (
                                <div class="photo-ring w-28 h-28 rounded-full border-4 border-dashed border-green/20 bg-green/5 flex flex-col items-center justify-center gap-1">
                                    <svg viewBox="0 0 24 24" width="36" height="36" fill="currentColor" class="text-green/25">
                                        <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
                                    </svg>
                                    <span class="text-[9px] text-green/30 font-bold uppercase tracking-wider">Foto disini</span>
                                </div>
                            )}
                        </div>

                        <!-- Identity -->
                        <div class="text-center mb-5">
                            <h3 class="text-lg font-extrabold text-ink">{m.name}</h3>
                            <p class="text-[11px] font-bold uppercase tracking-wider text-green mt-1">{m.role}</p>
                        </div>

                        <!-- Bio -->
                        <p class="text-sm text-ink/55 leading-relaxed text-center mb-6">{m.bio}</p>

                        <!-- Fun facts -->
                        <div class="border-t border-ink/8 pt-5 mb-5">
                            <p class="text-[10px] font-black uppercase tracking-wider text-ink/30 mb-3 flex items-center gap-1.5">
                                <span class="text-yellow">★</span> Fun Facts
                            </p>
                            <ul class="space-y-2">
                                {m.funFacts.map((f) => (
                                    <li class="flex items-start gap-2 text-xs text-ink/55 leading-relaxed">
                                        <span class="text-green shrink-0 mt-0.5 font-bold">›</span>
                                        {f}
                                    </li>
                                ))}
                            </ul>
                        </div>

                        <!-- Social -->
                        {(m.linkedin || m.github || m.portfolio) && (
                            <div class="flex gap-2 pt-4 border-t border-ink/8 flex-wrap">
                                {m.linkedin && (
                                    <a href={m.linkedin} target="_blank" rel="noopener noreferrer"
                                       class="flex-1 min-w-[80px] flex items-center justify-center gap-1.5 py-2 border border-ink/10 text-[11px] font-bold text-ink/45 hover:border-blue-500 hover:text-blue-500 transition-colors">
                                        <svg viewBox="0 0 24 24" width="13" height="13" fill="currentColor">
                                            <path d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14m-.5 15.5v-5.3a3.26 3.26 0 0 0-3.26-3.26c-.85 0-1.84.52-2.32 1.3v-1.11h-2.79v8.37h2.79v-4.93c0-.77.62-1.4 1.39-1.4a1.4 1.4 0 0 1 1.4 1.4v4.93h2.79M6.88 8.56a1.68 1.68 0 0 0 1.68-1.68c0-.93-.75-1.69-1.68-1.69a1.69 1.69 0 0 0-1.69 1.69c0 .93.76 1.68 1.69 1.68m1.39 9.94v-8.37H5.5v8.37h2.77z"/>
                                        </svg>
                                        LinkedIn
                                    </a>
                                )}
                                {m.github && (
                                    <a href={m.github} target="_blank" rel="noopener noreferrer"
                                       class="flex-1 min-w-[80px] flex items-center justify-center gap-1.5 py-2 border border-ink/10 text-[11px] font-bold text-ink/45 hover:border-ink hover:text-ink transition-colors">
                                        <svg viewBox="0 0 24 24" width="13" height="13" fill="currentColor">
                                            <path d="M12 2A10 10 0 0 0 2 12c0 4.42 2.87 8.17 6.84 9.5.5.08.66-.23.66-.5v-1.69c-2.77.6-3.36-1.34-3.36-1.34-.46-1.16-1.11-1.47-1.11-1.47-.91-.62.07-.6.07-.6 1 .07 1.53 1.03 1.53 1.03.87 1.52 2.34 1.07 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.55-1.11-4.55-4.92 0-1.11.38-2 1.03-2.71-.1-.25-.45-1.29.1-2.64 0 0 .84-.27 2.75 1.02.79-.22 1.65-.33 2.5-.33.85 0 1.71.11 2.5.33 1.91-1.29 2.75-1.02 2.75-1.02.55 1.35.2 2.39.1 2.64.65.71 1.03 1.6 1.03 2.71 0 3.82-2.34 4.66-4.57 4.91.36.31.69.92.69 1.85V21c0 .27.16.59.67.5C19.14 20.16 22 16.42 22 12A10 10 0 0 0 12 2z"/>
                                        </svg>
                                        GitHub
                                    </a>
                                )}
                                {m.portfolio && (
                                    <a href={m.portfolio} target="_blank" rel="noopener noreferrer"
                                       class="flex-1 min-w-[80px] flex items-center justify-center gap-1.5 py-2 border border-ink/10 text-[11px] font-bold text-ink/45 hover:border-green hover:text-green transition-colors">
                                        <svg viewBox="0 0 24 24" width="13" height="13" fill="currentColor">
                                            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/>
                                        </svg>
                                        Portfolio
                                    </a>
                                )}
                            </div>
                        )}
                    </div>
                </div>
            ))}
        </div>
    </section>

    <!-- ══ FUN STATS ═══════════════════════════════════ -->
    <section class="-mx-4 sm:-mx-8 md:-mx-14 lg:-mx-20 px-4 sm:px-8 md:px-14 lg:px-20 py-16"
             style="background:#111;">

        <div data-reveal="up" class="text-center mb-12">
            <p class="text-[11px] font-black uppercase tracking-[.2em] text-green mb-2">By the numbers</p>
            <h2 class="text-3xl font-extrabold uppercase text-white">Fakta Pembangunan Portal</h2>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-3 max-w-2xl mx-auto">
            {[
                { v:"1000+", l:"Jam coding",     e:"⌨️" },
                { v:"∞",     l:"Gelas kopi",     e:"☕" },
                { v:"999",   l:"Bug diperbaiki", e:"🐛" },
                { v:"1",     l:"Portal keren",   e:"🚀" },
            ].map((s,i) => (
                <div data-reveal="up" data-delay={String(i+1)}
                     class="text-center border border-white/8 p-5 bg-white/[0.03]">
                    <div class="text-2xl mb-2">{s.e}</div>
                    <p class="text-3xl font-black text-white mb-1">{s.v}</p>
                    <p class="text-[10px] font-bold uppercase tracking-wider text-white/30">{s.l}</p>
                </div>
            ))}
        </div>
    </section>

    <!-- ══ CLOSING ═════════════════════════════════════ -->
    <section class="py-24 text-center">
        <div data-reveal="scale" class="max-w-lg mx-auto">
            <div class="text-5xl mb-5">🫶</div>
            <h3 class="text-2xl font-extrabold uppercase tracking-tight text-ink mb-3">
                Terima Kasih Sudah Menemukan Ini
            </h3>
            <p class="text-sm text-ink/45 leading-relaxed mb-8 max-w-sm mx-auto">
                Portal ini dibuat dengan sepenuh hati untuk pelayanan publik yang lebih baik.
                Kalau nemu bug, anggap aja <em>fitur eksklusif</em>. 😄
            </p>
            <div class="flex flex-wrap items-center justify-center gap-3">
                <a href="/"
                   class="inline-flex items-center gap-2 px-6 py-3 bg-green text-white text-sm font-bold uppercase tracking-wider hover:bg-green/90 transition-colors">
                    <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor">
                        <path d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"/>
                    </svg>
                    Kembali ke Beranda
                </a>
                <a href="/portal"
                   class="inline-flex items-center gap-2 px-6 py-3 border border-ink/15 text-sm font-bold uppercase tracking-wider text-ink/50 hover:border-green hover:text-green transition-colors">
                    Jelajahi Portal
                </a>
            </div>
        </div>
    </section>

    <section class="text-center max-md:hidden">
        <p class="text-xs text-ink/45 leading-relaxed mb-8 max-w-sm mx-auto">
            <em> 🤫 Husshhh ada 1 cheat code lagi buat trigger easter egg </em>
        </p>
    </section>

</BaseLayout>

<script>
{
    const obs = new IntersectionObserver(
        (entries) => entries.forEach((e) => {
            if (e.isIntersecting) { e.target.classList.add("visible"); obs.unobserve(e.target); }
        }),
        { threshold: 0.1, rootMargin: "0px 0px -40px 0px" },
    );
    document.querySelectorAll("[data-reveal]").forEach((el) => obs.observe(el));

    // Konami code easter egg dalam easter egg 🥚🥚
    const CODE = ["ArrowUp","ArrowUp","ArrowDown","ArrowDown",
                  "ArrowLeft","ArrowRight","ArrowLeft","ArrowRight","b","a"];
    let pos = 0;
    let idleTimer: ReturnType<typeof setTimeout> | null = null;

    document.addEventListener("keydown", (e) => {
        // Reset timer kalau idle > 2 detik
        if (idleTimer) clearTimeout(idleTimer);
        idleTimer = setTimeout(() => { pos = 0; }, 2000);

        if (e.key === CODE[pos]) {
            pos++;
            if (pos === CODE.length) {
                pos = 0;
                if (idleTimer) clearTimeout(idleTimer);
                document.body.style.transition = "filter .4s ease";
                document.body.style.filter = "hue-rotate(180deg)";
                setTimeout(() => {
                    document.body.style.filter = "";
                    setTimeout(() => { document.body.style.transition = ""; }, 400);
                }, 3000);
            }
        } else {
            // Kalau salah, cek apakah key ini cocok jadi start baru
            pos = e.key === CODE[0] ? 1 : 0;
        }
    });
}
</script>
