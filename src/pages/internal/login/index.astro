---
import "../../../styles/global.css";
import AsnLoginForm from "../../../components/Svelte/AsnLoginForm.svelte";
import { Icon } from "astro-icon/components";

const features = [
    {
        icon: "mdi:calendar-clock",
        label: "Pengajuan Cuti, Izin, dan Sakit secara online",
    },
    {
        icon: "mdi:account-arrow-up",
        label: "Permohonan Kenaikan Pangkat, Mutasi, dan Kepegawaian lainnya",
    },
    {
        icon: "mdi:file-document-multiple-outline",
        label: "Permintaan Slip Gaji, Laporan SPT, dan dokumen administratif",
    },
    {
        icon: "mdi:clipboard-check-outline",
        label: "Pencatatan Kinerja Harian, Tugas Luar, dan sistem internal",
    },
];
---

<html lang="id">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <title>Login ASN — Kemenag Kota Probolinggo</title>
    </head>

    <body class="min-h-screen bg-cream lg:h-screen lg:grid lg:grid-cols-2 lg:overflow-hidden">
        <!-- ══════════════════════════════════════════════════════════
         LEFT PANEL — login form (all sizes)
    ══════════════════════════════════════════════════════════════ -->
        <div
            data-anim="form"
            class="flex flex-col items-center justify-center px-6 py-12 sm:py-16 lg:py-10 lg:overflow-y-auto min-h-screen lg:min-h-0"
        >
            <!-- Mobile/tablet brand header (hidden on desktop where right panel shows) -->
            <div class="lg:hidden w-full max-w-sm mb-8">
                <div class="flex items-center gap-3 mb-6">
                    <img src="/logo.png" alt="Logo" class="w-10 sm:w-12" />
                    <div class="uppercase leading-tight">
                        <p class="text-[11px] sm:text-xs font-semibold">Kantor Kementerian Agama</p>
                        <p class="text-[11px] sm:text-xs font-semibold">Kota Probolinggo</p>
                    </div>
                </div>
                <div class="inline-flex items-center gap-2 bg-green/10 border border-green/25 rounded-full px-3 py-1 mb-1">
                    <span class="w-1.5 h-1.5 rounded-full bg-green animate-pulse"></span>
                    <span class="text-[11px] font-bold text-green uppercase tracking-widest">Portal ASN</span>
                </div>
            </div>

            <div class="w-full max-w-sm">
                <AsnLoginForm client:load />
            </div>
        </div>

        <!-- ══════════════════════════════════════════════════════════
         RIGHT PANEL — brand & feature info (desktop only)
    ══════════════════════════════════════════════════════════════ -->
        <div class="hidden lg:flex flex-col relative overflow-hidden h-full">
            <!-- Backgrounds -->
            <div
                class="absolute inset-0 bg-linear-to-br from-[#0a1a0c] via-[#0f2212] to-[#071510]"
            >
            </div>
            <div class="absolute inset-0 dot-grid opacity-[0.07]"></div>
            <div
                class="absolute -bottom-24 -left-24 w-96 h-96 bg-green/20 rounded-full blur-3xl pointer-events-none"
            >
            </div>
            <div
                class="absolute top-1/3 right-0 w-64 h-64 bg-green/10 rounded-full blur-3xl pointer-events-none"
            >
            </div>

            <!-- Content -->
            <div class="relative z-10 flex flex-col h-full px-12 py-10">
                <!-- Hero text -->
                <div class="flex-1 flex flex-col justify-center max-w-md">
                    <div
                        data-anim="badge"
                        class="inline-flex items-center gap-2 bg-green/20 border border-green/30 rounded-full px-3 py-1 mb-6 w-fit"
                    >
                        <span
                            class="w-1.5 h-1.5 rounded-full bg-green animate-pulse"
                        ></span>
                        <span
                            class="text-[11px] font-bold text-green/90 uppercase tracking-widest"
                            >Panel ASN</span
                        >
                    </div>

                    <h1
                        data-anim="heading"
                        class="text-3xl xl:text-4xl font-extrabold text-white uppercase leading-tight mb-4"
                    >
                        layanan Internal<br />
                        <span class="text-green">Khusus</span> ASN
                    </h1>

                    <p
                        data-anim="desc"
                        class="text-sm text-white/45 leading-relaxed mb-10"
                    >
                        Sistem manajemen layanan khusus Pegawai ASN Kementerian
                        Agama Kota Probolinggo.
                    </p>

                    <!-- Feature list -->
                    <div data-anim="features" class="space-y-4">
                        {
                            features.map((f, i) => (
                                <div
                                    class="flex items-start gap-3"
                                    style={`animation-delay:${0.3 + i * 0.1}s`}
                                >
                                    <div class="w-8 h-8 rounded-lg bg-green/15 border border-green/20 flex items-center justify-center shrink-0 mt-0.5">
                                        <Icon
                                            name={f.icon}
                                            width="16"
                                            height="16"
                                            class="text-green"
                                        />
                                    </div>
                                    <p class="text-[13px] text-white/55 leading-snug pt-1.5">
                                        {f.label}
                                    </p>
                                </div>
                            ))
                        }
                    </div>
                </div>

                <!-- Bottom note -->
                <div
                    data-anim="footer"
                    class="flex items-center gap-2 border-t border-white/8 pt-5"
                >
                    <Icon
                        name="mdi:lock"
                        width="16"
                        height="16"
                        class="text-white/25"
                    />
                    <p class="text-[11px] text-white/25">
                        Akses dibatasi. Hanya pegawai yang memiliki otorisasi
                        yang dapat masuk.
                    </p>
                </div>
            </div>
        </div>
    </body>
</html>

<style>
    .dot-grid {
        background-image: radial-gradient(circle, #fff 1px, transparent 1px);
        background-size: 28px 28px;
    }

    /* ── Entrance animations ───────────────────────────── */
    [data-anim="form"] {
        animation: fadeUp 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.1s both;
    }
    [data-anim="badge"] {
        animation: fadeDown 0.5s cubic-bezier(0.16, 1, 0.3, 1) 0.05s both;
    }
    [data-anim="heading"] {
        animation: fadeUp 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.15s both;
    }
    [data-anim="desc"] {
        animation: fadeUp 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.22s both;
    }
    [data-anim="features"] {
        animation: fadeUp 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.3s both;
    }
    [data-anim="footer"] {
        animation: fadeUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.45s both;
    }

    @keyframes fadeDown {
        from {
            opacity: 0;
            transform: translateY(-12px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
    @keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>
