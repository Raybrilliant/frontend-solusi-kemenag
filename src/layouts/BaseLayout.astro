---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import FloatingActions from "../components/Svelte/FloatingActions.svelte";
import { Icon } from "astro-icon/components";

const {
    title,
    description,
    ogTitle,
    ogDescription,
    ogImage,
    ogType = "website",
    canonicalUrl,
    robots = "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1",
    structuredData,
} = Astro.props;

const SITE_URL = "https://kemenagkotaprobolinggo.id";
const DEFAULT_DESC =
    "Kantor Kementerian Agama Kota Probolinggo. Melayani masyarakat dengan integritas untuk mewujudkan masyarakat yang taat beragama, rukun, cerdas, dan sejahtera.";
const DEFAULT_IMAGE = `${SITE_URL}/logo.png`;

const resolvedTitle = title
    ? `${title} — Kantor Kementerian Agama Kota Probolinggo`
    : "Kantor Kementerian Agama Kota Probolinggo";
const resolvedDescription = description ?? ogDescription ?? DEFAULT_DESC;
const resolvedOgTitle = ogTitle ?? resolvedTitle;
const resolvedOgDescription = ogDescription ?? resolvedDescription;
const resolvedOgImage = ogImage ?? DEFAULT_IMAGE;
const resolvedCanonicalUrl = canonicalUrl
    ? new URL(canonicalUrl, SITE_URL).href
    : new URL(Astro.url.pathname, SITE_URL).href;
const resolvedOgUrl = resolvedCanonicalUrl;
const structuredDataItems = Array.isArray(structuredData)
    ? structuredData
    : structuredData
      ? [structuredData]
      : [];
---

<html lang="id" class="scroll-smooth">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="generator" content={Astro.generator} />
        <meta name="description" content={resolvedDescription} />
        <meta name="robots" content={robots} />
        <meta
            name="author"
            content="Kantor Kementerian Agama Kota Probolinggo"
        />
        <meta name="theme-color" content="#0F6B44" />
        <meta
            name="format-detection"
            content="telephone=no, address=no, email=no"
        />
        <meta
            name="keywords"
            content="Kantor Kementerian Agama, Kota Probolinggo, Solusi, Sistem Online Layanan Unggul Terintegrasi"
        />
        <link rel="canonical" href={resolvedCanonicalUrl} />
        <title>{resolvedTitle}</title>

        <!-- Open Graph -->
        <meta property="og:type" content={ogType} />
        <meta property="og:site_name" content="Kemenag Kota Probolinggo" />
        <meta property="og:locale" content="id_ID" />
        <meta property="og:url" content={resolvedOgUrl} />
        <meta property="og:title" content={resolvedOgTitle} />
        <meta property="og:description" content={resolvedOgDescription} />
        <meta property="og:image" content={resolvedOgImage} />
        <meta property="og:image:alt" content={resolvedOgTitle} />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />

        <!-- Twitter / X Card -->
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={resolvedOgTitle} />
        <meta name="twitter:description" content={resolvedOgDescription} />
        <meta name="twitter:image" content={resolvedOgImage} />
        <meta name="twitter:image:alt" content={resolvedOgTitle} />

        {
            structuredDataItems.map((item) => (
                <script
                    type="application/ld+json"
                    set:html={JSON.stringify(item)}
                />
            ))
        }
    </head>
    <body class="px-4 sm:px-8 md:px-14 lg:px-20 bg-cream">
        <Navbar />
        <slot />
        <footer
            class="-mx-4 sm:-mx-8 md:-mx-14 lg:-mx-20 px-4 sm:px-8 md:px-14 lg:px-20 mt-10 md:mt-20 py-7 bg-cream border-t border-ink/8"
        >
            <div
                class="flex flex-col sm:flex-row items-center justify-between gap-4"
            >
                <p class="text-[11px] text-ink/35 font-medium">
                    © {new Date().getFullYear()} Kantor Kementerian Agama Kota Probolinggo
                    · built with <span class="text-red-500 animate-pulse"
                        >♥</span
                    > by
                    <a
                        href="/easter-egg"
                        class="font-semibold text-ink/50 hover:text-green transition-colors underline-offset-2 hover:underline"
                        > Prakom</a
                    >
                </p>
                <div class="flex items-center gap-2">
                    <!-- Instagram -->
                    <a
                        href="https://www.instagram.com/kemenagkoprob/"
                        target="_blank"
                        rel="noopener noreferrer"
                        aria-label="Instagram"
                        class="w-8 h-8 flex items-center justify-center text-white bg-gradient-to-br from-[#F58529] via-[#DD2A7B] to-[#8134AF] border border-black/10 hover:scale-105 hover:shadow-md transition-all"
                    >
                        <Icon name="mdi:instagram" width="16" height="16" />
                    </a>
                    <!-- TikTok (inline SVG — tidak tersedia di MDI) -->
                    <a
                        href="#"
                        target="_blank"
                        rel="noopener noreferrer"
                        aria-label="TikTok"
                        class="w-8 h-8 flex items-center justify-center text-white bg-[#111111] border border-black/10 hover:scale-105 hover:shadow-md transition-all"
                    >
                        <svg
                            viewBox="0 0 24 24"
                            width="15"
                            height="15"
                            fill="currentColor"
                            aria-hidden="true"
                        >
                            <path
                                d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.27 6.27 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.95a8.28 8.28 0 0 0 4.84 1.55V7.05a4.85 4.85 0 0 1-1.07-.36z"
                            ></path>
                        </svg>
                    </a>
                    <!-- Facebook -->
                    <a
                        href="https://www.facebook.com/kemenagkoprob/"
                        target="_blank"
                        rel="noopener noreferrer"
                        aria-label="Facebook"
                        class="w-8 h-8 flex items-center justify-center text-white bg-[#1877F2] border border-black/10 hover:scale-105 hover:shadow-md transition-all"
                    >
                        <Icon name="mdi:facebook" width="16" height="16" />
                    </a>
                </div>
            </div>
        </footer>
        <FloatingActions client:idle />
    </body>
</html>
