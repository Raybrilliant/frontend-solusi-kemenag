---
import "../styles/global.css";

let { title } = Astro.props;

// User info from middleware
const user = Astro.locals.user ?? null;
const userName = user?.nama ?? "ASN";
const userRole = user?.role ?? "";

// ── Role badge config ─────────────────────────────────
const roleBadgeConfig: Record<
    string,
    { label: string; color: string; bg: string }
> = {
    super_admin: {
        label: "Super Admin",
        color: "text-amber-600",
        bg: "bg-amber-100 border-amber-300",
    },
    admin: {
        label: "Admin",
        color: "text-blue-600",
        bg: "bg-blue-100 border-blue-300",
    },
    operator: {
        label: "Operator",
        color: "text-purple-600",
        bg: "bg-purple-100 border-purple-300",
    },
    humas: {
        label: "Humas",
        color: "text-teal-600",
        bg: "bg-teal-100 border-teal-300",
    },
};
const badge = roleBadgeConfig[userRole] ?? {
    label: "ASN",
    color: "text-green",
    bg: "bg-green/10 border-green/20",
};
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="generator" content={Astro.generator} />
        <meta name="robots" content="noindex, nofollow" />
        <title>
            {title ? `${title} - ` : ""} Kantor Kementerian Agama Kota Probolinggo
        </title>
    </head>
    <body class="px-4 sm:px-8 md:px-14 lg:px-20 mb-10 md:mb-20 bg-cream">
        <!-- Internal Navbar -->
        <header class="border-b border-ink/8 py-4 lg:py-5 mb-8 lg:mb-12">
            <nav class="flex justify-between items-center">
                <!-- Logo -->
                <a
                    href="/internal"
                    class="flex gap-3 items-center hover:opacity-80 transition-opacity"
                >
                    <img src="/logo.png" class="w-10 lg:w-13" alt="Logo" />
                    <div
                        class="-space-y-1 lg:-space-y-2 uppercase leading-tight"
                    >
                        <h3 class="text-[11px] lg:text-sm font-semibold">
                            Kantor Kementerian Agama
                        </h3>
                        <h3 class="text-[11px] lg:text-sm font-semibold">
                            Kota Probolinggo
                        </h3>
                    </div>
                </a>

                <!-- Right side: ASN badge + user name + logout -->
                <div class="flex items-center gap-3 lg:gap-4">
                    <!-- Role badge -->
                    <div
                        class="flex items-center gap-2 {badge.bg} rounded-full px-3 py-1.5"
                    >
                        <span
                            class="w-1.5 h-1.5 rounded-full {badge.color.replace('text-', 'bg-')}"
                        ></span>
                        <span
                            class="text-[11px] font-bold {badge.color} uppercase tracking-wider"
                            >{badge.label}</span
                        >
                    </div>

                    <!-- User name (hidden on small mobile) -->
                    <span
                        class="text-sm font-semibold text-ink/60 hidden sm:inline"
                        >{userName}</span
                    >

                    <!-- Logout button -->
                    <a
                        href="/api/internal/auth/logout"
                        class="flex items-center gap-1.5 text-sm font-semibold text-ink/40 hover:text-red-500 transition-colors"
                    >
                        <svg viewBox="0 0 24 24" class="w-4 h-4 shrink-0">
                            <path
                                fill="currentColor"
                                d="M16 17v-3H9v-4h7V7l5 5l-5 5M14 2a2 2 0 0 1 2 2v2h-2V4H5v16h9v-2h2v2a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9z"
                            ></path>
                        </svg>
                        <span class="hidden sm:inline">Keluar</span>
                    </a>
                </div>
            </nav>
        </header>

        <!-- Page Content -->
        <slot />
    </body>
</html>
